generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model MobileAuthSession {
  id        String   @id
  sessionId String   @unique
  token     String?
  userData  String?
  error     String?
  expires   DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id      String   @id
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Project {
  id                String        @id
  name              String
  description       String?
  logoUrl           String?
  coverUrl          String?
  backgroundUrl     String?
  logoHorizontalUrl String?
  link              String?
  email             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  defaultEntryRole  String        @default("visitor")
  Action            Action[]
  Attachment        Attachment[]
  Category          Category[]
  MainMenu          MainMenu[]
  Post              Post[]
  Tag               Tag[]
  UserProject       UserProject[]
  UserInterest UserInterest[]
  AnpofEvent        AnpofEvent[]
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole      @default(VISITOR)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  Account       Account[]
  AuthoredPosts Post[]        @relation("PostAuthor")
  EditedPosts   Post[]        @relation("PostEditor")
  Session       Session[]
  UserProject   UserProject[]
  UserInterest UserInterest[]
}

model UserProject {
  userId    String
  projectId String
  role      String?
  createdAt DateTime @default(now())
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model UserInterest {
  userId    String
  postId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Post {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  summary     String?
  content     String?
  imageUrl    String?
  projectId   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  publishedAt DateTime?
  createdBy   String?
  updatedBy   String?
  menuItems   MenuItem[]
  author      User?            @relation("PostAuthor", fields: [createdBy], references: [id])
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  editor      User?            @relation("PostEditor", fields: [updatedBy], references: [id])
  actions     PostAction[]
  attachments PostAttachment[]
  tags        PostTag[]
  categories  PostCategory[]
  UserInterest UserInterest[]
}

model Category {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?
  imageUrl    String?
  projectId   String
  type        String?    @default("Postagens") // "Postagens" or "Eventos"
  createdAt   DateTime   @default(now())
  isVisible   Boolean    @default(true)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  menuItems   MenuItem[]
  posts       PostCategory[]
}

model PostCategory {
  postId     String
  categoryId String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

model Tag {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  projectId String
  createdAt DateTime  @default(now())
  posts     PostTag[]
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model MainMenu {
  id        String     @id @default(cuid())
  title     String
  projectId String
  createdAt DateTime   @default(now())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items     MenuItem[]
}

model MenuItem {
  id         String     @id @default(cuid())
  title      String
  url        String?
  order      Int        @default(0)
  type       String
  menuId     String
  parentId   String?
  categoryId String?
  postId     String?
  createdAt  DateTime   @default(now())
  category   Category?  @relation(fields: [categoryId], references: [id])
  menu       MainMenu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent     MenuItem?  @relation("SubItems", fields: [parentId], references: [id], onDelete: Cascade)
  subItems   MenuItem[] @relation("SubItems")
  post       Post?      @relation(fields: [postId], references: [id])
}

model Attachment {
  id          String           @id @default(cuid())
  title       String
  description String?
  url         String
  type        String
  projectId   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  posts       PostAttachment[]
}

model PostAttachment {
  postId       String
  attachmentId String
  attachment   Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, attachmentId])
}

model Action {
  id          String       @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  type        String
  startDate   DateTime?
  endDate     DateTime?
  projectId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  organizer   String?
  url         String?
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  posts       PostAction[]
}

model PostAction {
  postId   String
  actionId String
  action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, actionId])
}

enum UserRole {
  ADMIN
  USER
  VISITOR
  BLOCKED
}

model AnpofEvent {
  id        String   @id @default(cuid())
  url       String   @unique
  title     String
  eventDate String?
  content   String?
  isUsed    Boolean  @default(false)
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
