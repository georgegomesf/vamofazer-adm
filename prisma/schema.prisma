generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Action {
  id            String        @id
  title         String
  description   String?
  imageUrl      String?
  type          String
  startDate     DateTime?
  endDate       DateTime?
  projectId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  organizer     String?
  url           String?
  backgroundUrl String?
  Project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ActionGroup   ActionGroup[]
}

model ActionGroup {
  actionId String
  groupId  String
  Action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  Group    Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([actionId, groupId])
}

model Group {
  id              String            @id
  name            String
  description     String?
  projectId       String
  parentId        String?
  isVisible       Boolean           @default(true)
  maxSpots        Int?
  allowWaitlist   Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  backgroundUrl   String?
  logoUrl         String?
  enrollmentEnd   DateTime?
  enrollmentStart DateTime?
  ActionGroup     ActionGroup[]
  Group           Group?            @relation("GroupToGroup", fields: [parentId], references: [id])
  other_Group     Group[]           @relation("GroupToGroup")
  Project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  GroupMembership GroupMembership[]
  Invitation      Invitation[]
}

model GroupMembership {
  id               String           @id
  groupId          String
  userId           String?
  name             String?
  email            String?
  status           MembershipStatus @default(PENDING)
  additionMethod   AdditionMethod   @default(DIRECT)
  confirmationCode String?
  isConfirmed      Boolean          @default(false)
  confirmedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  isActive         Boolean          @default(true)
  role             GroupMemberRole  @default(MEMBER)
  Group            Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  User             User?            @relation(fields: [userId], references: [id])
}

model Invitation {
  id               String           @id
  groupId          String
  code             String           @unique
  type             InvitationType   @default(INDIVIDUAL)
  confirmationType ConfirmationType @default(INDIVIDUAL)
  maxUses          Int?
  currentUses      Int              @default(0)
  expiresAt        DateTime?
  createdAt        DateTime         @default(now())
  targetNames      String?
  targetUserId     String?
  isUsed           Boolean          @default(false)
  Group            Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model MobileAuthSession {
  id        String   @id
  sessionId String   @unique
  token     String?
  userData  String?
  error     String?
  expires   DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id      String   @id
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Project {
  id                 String        @id
  name               String
  description        String?
  logoUrl            String?
  coverUrl           String?
  backgroundUrl      String?
  logoHorizontalUrl  String?
  link               String?
  email              String?
  defaultEntryRole   String        @default("visitor")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime
  bestSellersLabel   String?
  bestSellersVisible Boolean       @default(false)
  countdownLabel     String?
  countdownVisible   Boolean       @default(false)
  defaultThumbUrl    String?
  heroLabel          String?
  heroVisible        Boolean       @default(false)
  homeSectionOrder   Json?
  newArrivalsLabel   String?
  newArrivalsVisible Boolean       @default(false)
  searchLabel        String?
  searchViewType     String?       @default("grid")
  searchVisible      Boolean       @default(true)
  theme              String?       @default("light")
  Action             Action[]
  Group              Group[]
  UserProject        UserProject[]
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String            @id
  name            String?
  email           String            @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            UserRole          @default(VISITOR)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Account         Account[]
  GroupMembership GroupMembership[]
  Session         Session[]
  UserProject     UserProject[]
}

model UserProject {
  userId    String
  projectId String
  role      String?
  createdAt DateTime @default(now())
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum AdditionMethod {
  DIRECT
  NEW_USER
  FORM_INTERNAL
  FORM_EXTERNAL
  INVITE
}

enum ConfirmationType {
  INDIVIDUAL
  COLLECTIVE
}

enum GroupMemberRole {
  OWNER
  ORGANIZER
  MEMBER
}

enum InvitationType {
  INDIVIDUAL
  COLLECTIVE
}

enum MembershipStatus {
  PENDING
  ACTIVE
  REJECTED
  WAITLIST
}

enum UserRole {
  ADMIN
  USER
  VISITOR
  BLOCKED
}
